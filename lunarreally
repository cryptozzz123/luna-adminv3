-- Key rotates every 48 hours. INSTALL_TIME is os.time() at first run.
-- We embed a compile-time anchor so re-runs within the 2-day window still work.
local EPOCH_ANCHOR = 1745000000  -- approximate epoch reference (update on release)
local PERIOD       = 60 * 60 * 48  -- 48 hours in seconds
local PERIOD_INDEX = math.floor((os.time() - EPOCH_ANCHOR) / PERIOD)

-- Script is considered "expired" if more than 2 periods have passed
-- (i.e. the user must get a new key at most every 2 days)

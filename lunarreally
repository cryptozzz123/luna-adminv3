RunSvc.RenderStepped:Connect(function()
    local cam = workspace.CurrentCamera
    local vp  = cam.ViewportSize
    local ori = Vector2.new(vp.X / 2, vp.Y)
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LP then continue end
        if (S.esp or S.tracer) and not ESPData[p] then initESP(p) end
        local d = ESPData[p]
        if not d then continue end
        local ch   = p.Character
        local root = ch and ch:FindFirstChild("HumanoidRootPart")
        local hum  = ch and ch:FindFirstChildOfClass("Humanoid")
        if not root then hideESP(d); continue end
        local sp, vis = cam:WorldToViewportPoint(root.Position)
        if not vis or sp.Z <= 0 then hideESP(d); continue end
        local spT = cam:WorldToViewportPoint(root.Position + Vector3.new(0, 3.1, 0))
        local spB = cam:WorldToViewportPoint(root.Position - Vector3.new(0, 2.7, 0))
        local sx, sy = sp.X, sp.Y
        local boxH   = math.abs(spB.Y - spT.Y)
        local boxW   = boxH * 0.5
        local dist   = math.floor((root.Position - cam.CFrame.Position).Magnitude)
        local col    = espCol(p)
        if S.esp then
            pcall(function()
                d.box.Visible  = true; d.box.Color = col
                d.box.Position = Vector2.new(sx - boxW / 2, spT.Y)
                d.box.Size     = Vector2.new(boxW, boxH)
                d.name.Visible   = true; d.name.Color = col
                d.name.Position  = Vector2.new(sx, spT.Y - 16)
                d.name.Text      = S.showDist and (p.Name .. " [" .. dist .. "m]") or p.Name
                if S.showHP and hum then
                    local hp = math.max(0, hum.Health)
                    local mp = math.max(1, hum.MaxHealth)
                    local r2 = math.clamp(hp / mp, 0, 1)
                    local hc = Color3.new(1 - r2, r2 * 0.88, 0.05)
                    d.hp.Visible     = true; d.hp.Color = hc
                    d.hp.Position    = Vector2.new(sx, spB.Y + 3)
                    d.hp.Text        = math.floor(hp) .. " HP"
                    d.hbBg.Visible   = true
                    d.hbBg.Position  = Vector2.new(sx - boxW / 2 - 7, spT.Y)
                    d.hbBg.Size      = Vector2.new(4, boxH)
                    d.hbFill.Visible = true; d.hbFill.Color = hc
                    d.hbFill.Position = Vector2.new(sx - boxW / 2 - 7, spT.Y + boxH * (1 - r2))
                    d.hbFill.Size     = Vector2.new(4, boxH * r2)
                else
                    d.hp.Visible = false; d.hbBg.Visible = false; d.hbFill.Visible = false
                end
            end)
        else
            d.box.Visible = false; d.name.Visible = false
            d.hp.Visible  = false; d.hbBg.Visible = false; d.hbFill.Visible = false
        end
        if S.tracer then
            pcall(function()
                d.tracer.Visible = true; d.tracer.Color = col
                d.tracer.From    = ori
                d.tracer.To      = Vector2.new(sx, sy)
            end)
        else
            pcall(function() d.tracer.Visible = false end)
        end
    end
    for p in pairs(ESPData) do
        if not p or not p.Parent then killESP(p) end
    end
end)


-- Uses task.delay (fires even if earlier code errored in a task.spawn)
-- The loading bar tween takes 2.4s; we wait 2.8s then fade out.
local function DoLoadTransition()
    pcall(function()
        Tw(LCard,0.30,{BackgroundTransparency=1},Enum.EasingStyle.Quad,Enum.EasingDirection.In)
        TwnSvc:Create(LCard,TweenInfo.new(0.30,Enum.EasingStyle.Quad,Enum.EasingDirection.In),
            {Size=UDim2.new(0,260,0,0)}):Play()
    end)
    task.wait(0.1)
    pcall(function() Tw(LBG,0.40,{BackgroundTransparency=1}) end)
    task.wait(0.45)
    pcall(function() LoadGui:Destroy() end)
    pcall(function()
        Gui.Enabled = true
        Win.Visible = true
        Win.Size    = UDim2.new(0,0,0,0)
        TwB(Win,0.50,{Size=UDim2.new(0,WIN_W,0,WIN_H)})
    end)
end


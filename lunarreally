-- ────────────────── [9] NDS DISASTER DETECTION ──────────────────
-- Scans workspace direct children for known NDS disaster models.
-- This is the most reliable method for Natural Disaster Survival.
local NDS_MODELS = {
    Flood            = "Flood",
    Fire             = "Fire",
    Meteorite        = "Meteor Shower",
    Earthquake       = "Earthquake",
    Tsunami          = "Tsunami",
    Tornado          = "Tornado",
    Blizzard         = "Blizzard",
    AcidRain         = "Acid Rain",
    Sandstorm        = "Sandstorm",
    VolcanicEruption = "Volcanic Eruption",
    FlashFlood       = "Flash Flood",
    ["Flash Flood"]  = "Flash Flood",
    ToxicGas         = "Toxic Gas",
    SuperHeat        = "Super Heat",
    Hail             = "Hail Storm",
    Lightning        = "Lightning Storm",
    IceStorm         = "Ice Storm",
    ThunderStorm     = "Thunder Storm",
}

local function GetDisaster()
    -- Pass 1: workspace direct children matching known model names
    for name, display in pairs(NDS_MODELS) do
        if workspace:FindFirstChild(name) then return display end
    end
    -- Pass 2: any workspace child whose name contains a disaster keyword
    local keywords = {"flood","fire","meteor","quake","tsunami","tornado",
                      "blizzard","acid","sand","volcan","toxic","heat","hail","lightning","ice","thunder"}
    for _, child in ipairs(workspace:GetChildren()) do
        local n = child.Name:lower()
        for _, kw in ipairs(keywords) do
            if n:find(kw,1,true) and child:IsA("Model") then
                return child.Name
            end
        end
    end
    -- Pass 3: StringValues named Disaster / CurrentDisaster in RS or WS
    local rs = game:GetService("ReplicatedStorage")
    for _, root in ipairs({rs, workspace}) do
        for _, v in ipairs(root:GetChildren()) do
            if v:IsA("StringValue") then
                local n = v.Name:lower()
                if (n=="disaster" or n=="currentdisaster" or n=="selecteddisaster") and v.Value~="" and v.Value~="None" then
                    return v.Value
                end
            end
        end
    end
    -- Pass 4: Countdown implies active disaster
    local cd = workspace:FindFirstChild("Countdown") or workspace:FindFirstChild("CountDown")
    if cd and (cd:IsA("IntValue") or cd:IsA("NumberValue")) and (cd.Value or 0) > 0 then
        return "Active — "..cd.Value.."s left"
    end
    return "None / Waiting"
end


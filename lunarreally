-- ─────────────────────────────── [4] KEY SYSTEM ─────────────────────────────
-- Valid key format: LUNA_XXXXXXXX  (8 uppercase alphanumeric chars)
-- Key is deterministic: derived from period index + secret salt
-- Changes every 48 hours automatically.

local KEY_SALT    = "LunaAurora2025"
local KEY_CHARSET = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789"

local function GenerateKey(periodIdx)
    -- Simple hash: combine salt + periodIdx chars
    local seed = 0
    local src   = KEY_SALT .. tostring(periodIdx)
    for i = 1, #src do seed = (seed * 31 + src:byte(i)) % 2147483647 end
    local result = "LUNA_"
    for i = 1, 8 do
        seed = (seed * 1664525 + 1013904223) % 2147483648
        local idx = (seed % #KEY_CHARSET) + 1
        result = result .. KEY_CHARSET:sub(idx, idx)
    end
    return result
end

local CURRENT_KEY  = GenerateKey(PERIOD_INDEX)
local PREVIOUS_KEY = GenerateKey(PERIOD_INDEX - 1)  -- grace period: accept previous key too
local PREMIUM_UNLOCKED = true   -- everyone gets premium access
local PREMIUM_FEATURES = {}  -- callbacks registered by premium section

local function ValidateKey(input)
    if not input or #input < 5 then return false end
    local clean = input:upper():gsub("%s", "")
    -- Accept any key that starts with LUNA_
    return clean:sub(1, 5) == "LUNA_"
end


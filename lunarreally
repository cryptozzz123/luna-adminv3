    BtnLbl.Font=Enum.Font.GothamSemibold; BtnLbl.Text=name; BtnLbl.TextColor3=C.tDim; BtnLbl.TextSize=12
    BtnLbl.TextXAlignment=Enum.TextXAlignment.Left; BtnLbl.Parent=Btn

    -- Page
    local Page=Instance.new("ScrollingFrame"); Page.BackgroundTransparency=1; Page.BorderSizePixel=0
    Page.Size=UDim2.new(1,0,1,0); Page.CanvasSize=UDim2.new(0,0,0,0)
    Page.AutomaticCanvasSize=Enum.AutomaticSize.Y
    Page.ScrollBarThickness=3; Page.ScrollBarImageColor3=C.togOn
    Page.Visible=false; Page.ZIndex=3; Page.Parent=Content
    ListL(Page,Enum.FillDirection.Vertical,0)

    Pages[name]={Btn=Btn,Ico=BtnIco,Lbl=BtnLbl,Page=Page}

    Btn.MouseButton1Click:Connect(function()
        for _,t in pairs(Pages) do
            t.Page.Visible=false; Tw(t.Btn,0.12,{BackgroundTransparency=1})
            Tw(t.Ico,0.12,{TextColor3=C.tDim}); Tw(t.Lbl,0.12,{TextColor3=C.tDim})

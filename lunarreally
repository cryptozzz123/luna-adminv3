local lockoutUntil   = 0
local failedAttempts = 0
KCheckBtn.MouseButton1Click:Connect(function()
    if os.clock() < lockoutUntil then
        KStatus.TextColor3 = C.err
        KStatus.Text = "⏱️  Wait " .. math.ceil(lockoutUntil - os.clock()) .. "s before retrying"
        return
    end
    local input = KInp.Text
    if ValidateKey(input) then
        -- ✅ Key accepted
        failedAttempts  = 0
        lockoutUntil    = 0
        KStatus.TextColor3 = C.ok
        KStatus.Text       = "✅  Key accepted! Welcome to Premium."
        Tw(KCheckBtn, 0.2, { BackgroundColor3 = Color3.fromRGB(28,145,72) })
        KCheckBtn.Text = "✅  Unlocked!"
        PREMIUM_UNLOCKED = true
        task.delay(1.2, function()
            task.spawn(CloseKeyUI)
            task.delay(0.5, function()
                for _, cb in ipairs(PREMIUM_FEATURES) do pcall(cb) end
            end)
        end)
    else
        -- ❌ Wrong key
        failedAttempts += 1
        KStatus.TextColor3 = C.err
        if failedAttempts >= 8 then
            lockoutUntil = os.clock() + 30
            KStatus.Text = "❌  Too many attempts. 30s cooldown."
        elseif input == "" then
            KStatus.Text = "⚠️  Please enter a key first."
        else
            KStatus.Text = "❌  Invalid key. Must start with  LUNA_"

    local LL=Instance.new("TextLabel"); LL.BackgroundTransparency=1
    LL.Size=UDim2.new(0,70,1,0); LL.ZIndex=5; LL.Font=Enum.Font.GothamMedium
    LL.Text=labelTxt; LL.TextColor3=C.tSec; LL.TextSize=11
    LL.TextXAlignment=Enum.TextXAlignment.Left; LL.Parent=F

    -- TextBox (user types exact value)
    local TBWrap=Instance.new("Frame"); TBWrap.BackgroundColor3=C.card; TBWrap.BorderSizePixel=0
    TBWrap.Size=UDim2.new(1,-170,1,0); TBWrap.ZIndex=5; TBWrap.Parent=F; Corn(TBWrap,7)
    local tbsk=Strk(TBWrap,C.bdr,1)
    local TB=Instance.new("TextBox"); TB.BackgroundTransparency=1
    TB.Position=UDim2.new(0,8,0,0); TB.Size=UDim2.new(1,-16,1,0); TB.ZIndex=6
    TB.Font=Enum.Font.GothamSemibold
    TB.Text=isJump and tostring(S.jmp) or tostring(S.spd)
    TB.TextColor3=C.tPri; TB.TextSize=12; TB.TextXAlignment=Enum.TextXAlignment.Center
    TB.ClearTextOnFocus=false; TB.Parent=TBWrap
    TB.Focused:Connect(function() Tw(tbsk,0.12,{Color=C.togOn}) end)
    TB.FocusLost:Connect(function(enter)
        Tw(tbsk,0.12,{Color=C.bdr})
        local n=tonumber(TB.Text)
        if n then
            n=math.clamp(n,0,1000)
            if isJump then S.jmp=n; local h=GetHum(LP); if h then h.JumpPower=n end
            else S.spd=n; local h=GetHum(LP); if h then h.WalkSpeed=n end end
            TB.Text=tostring(n)
        else TB.Text=isJump and tostring(S.jmp) or tostring(S.spd) end
    end)

    -- + button
    local BtnP=Instance.new("TextButton"); BtnP.BackgroundColor3=Color3.fromRGB(36,80,165)
    BtnP.BorderSizePixel=0; BtnP.Size=UDim2.new(0,40,1,0); BtnP.ZIndex=5
    BtnP.Font=Enum.Font.GothamBold; BtnP.Text="+"; BtnP.TextColor3=C.tPri; BtnP.TextSize=14; BtnP.Parent=F; Corn(BtnP,7)
    BtnP.MouseButton1Click:Connect(function()
        local delta=isJump and 25 or 10
        if isJump then S.jmp=math.clamp(S.jmp+delta,0,1000) else S.spd=math.clamp(S.spd+delta,0,1000) end
        local h=GetHum(LP); if h then if isJump then h.JumpPower=S.jmp else h.WalkSpeed=S.spd end end
        TB.Text=isJump and tostring(S.jmp) or tostring(S.spd)
    end)

    -- - button
    local BtnM=Instance.new("TextButton"); BtnM.BackgroundColor3=Color3.fromRGB(48,42,68)
    BtnM.BorderSizePixel=0; BtnM.Size=UDim2.new(0,40,1,0); BtnM.ZIndex=5
    BtnM.Font=Enum.Font.GothamBold; BtnM.Text="−"; BtnM.TextColor3=C.tPri; BtnM.TextSize=14; BtnM.Parent=F; Corn(BtnM,7)
    BtnM.MouseButton1Click:Connect(function()
        local delta=isJump and 25 or 10
        if isJump then S.jmp=math.clamp(S.jmp-delta,0,1000) else S.spd=math.clamp(S.spd-delta,2,1000) end
        local h=GetHum(LP); if h then if isJump then h.JumpPower=S.jmp else h.WalkSpeed=S.spd end end
        TB.Text=isJump and tostring(S.jmp) or tostring(S.spd)
    end)

    -- Reset button
    local BtnR=Instance.new("TextButton"); BtnR.BackgroundColor3=Color3.fromRGB(38,38,46)
    BtnR.BorderSizePixel=0; BtnR.Size=UDim2.new(0,46,1,0); BtnR.ZIndex=5
    BtnR.Font=Enum.Font.GothamSemibold; BtnR.Text="Reset"; BtnR.TextColor3=C.tDim; BtnR.TextSize=10; BtnR.Parent=F; Corn(BtnR,7)
    BtnR.MouseButton1Click:Connect(function()
        if isJump then S.jmp=50; local h=GetHum(LP); if h then h.JumpPower=50 end; TB.Text="50"
        else S.spd=16; local h=GetHum(LP); if h then h.WalkSpeed=16 end; TB.Text="16" end
    end)

    return TB
end


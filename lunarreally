-- ════════════════════════════════
local function flingOne(victim)
    if flingBusy then return end
    flingBusy = true
    local mr = getRoot(LP)
    if not mr then flingBusy = false; return end
    local cf = mr.CFrame
    local sg = S.god
    S.god = true
    local h = getHum(LP)
    if h then h.MaxHealth = math.huge; h.Health = math.huge end
    local bav = Instance.new("BodyAngularVelocity")
    bav.MaxTorque       = Vector3.new(0, math.huge, 0)
    bav.AngularVelocity = Vector3.new(0, 999999, 0)
    bav.P               = math.huge
    bav.Parent          = mr
    for _ = 1, 16 do
        local tr = getRoot(victim)
        if not tr then break end
        pcall(function() mr.CFrame = tr.CFrame * CFrame.new(2.5, 0, 0) end)
        task.wait(0.05)
    end
    pcall(function() bav:Destroy() end)
    task.wait(0.04)
    pcall(function() mr.CFrame = cf end)
    S.god = sg
    if not sg then
        local hh = getHum(LP)
        if hh then hh.MaxHealth = 100; hh.Health = math.min(100, hh.Health) end
    end
    task.wait(0.5)
    flingBusy = false
end
local function flingAll()
    local t = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP then table.insert(t, p) end
    end
    for _, p in ipairs(t) do
        task.spawn(flingOne, p)
        task.wait(0.15)
    end
end


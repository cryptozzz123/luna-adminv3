-- Open / Close
local function OpenPanel()
    MinBtn.Visible=false; MinTip.Visible=false; Win.Visible=true
    Win.Size=UDim2.new(0,0,0,0)
    TwnSvc:Create(Win,TweenInfo.new(0.44,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Size=UDim2.new(0,WIN_W,0,WIN_H)}):Play()
end
local function ClosePanel()
    MinTip.Visible=false
    TwnSvc:Create(Win,TweenInfo.new(0.26,Enum.EasingStyle.Back,Enum.EasingDirection.In),{Size=UDim2.new(0,0,0,0)}):Play()
    task.wait(0.28); Win.Visible=false; MinBtn.Visible=true
end
CloseX.MouseButton1Click:Connect(function() task.spawn(ClosePanel) end)

-- ═══════════════════════════════════════════════════════════════
--   DRAGGING  —  Window + MinBtn
-- ═══════════════════════════════════════════════════════════════
local wDrag,wStart,wStartPos=false,nil,nil
local mDrag,mDragged,mStart,mBtnStart=false,false,nil,nil

TopBar.InputBegan:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1 then
        wDrag=true; wStart=i.Position; wStartPos=Win.Position
    end
end)
MinBtn.InputBegan:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1 then
        mDrag=true; mDragged=false; mStart=i.Position; mBtnStart=MinBtn.Position
    end
end)
UIS.InputChanged:Connect(function(i)
    if i.UserInputType~=Enum.UserInputType.MouseMovement then return end
    if wDrag then
        local d=i.Position-wStart
        Win.Position=UDim2.new(wStartPos.X.Scale,wStartPos.X.Offset+d.X,wStartPos.Y.Scale,wStartPos.Y.Offset+d.Y)
    end
    if mDrag then
        local d=i.Position-mStart
        if d.Magnitude>8 then
            mDragged=true; MinTip.Visible=false
            MinBtn.Position=UDim2.new(mBtnStart.X.Scale,mBtnStart.X.Offset+d.X,mBtnStart.Y.Scale,mBtnStart.Y.Offset+d.Y)
        end
    end
end)
UIS.InputEnded:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1 then
        if mDrag and not mDragged and MinBtn.Visible then OpenPanel() end
        wDrag=false; mDrag=false
    end
end)


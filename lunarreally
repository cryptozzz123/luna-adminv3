-- DISASTER DETECTION
-- ════════════════════════════════
local DIS_EXACT = {
    Flood="🌊 Flood", Fire="🔥 Fire", Meteorite="☄️ Meteor Shower",
    Earthquake="💥 Earthquake", Tsunami="🌊 Tsunami", Tornado="🌪️ Tornado",
    Blizzard="❄️ Blizzard", AcidRain="☠️ Acid Rain", Sandstorm="🏜️ Sandstorm",
    VolcanicEruption="🌋 Volcanic Eruption", FlashFlood="🌊 Flash Flood",
    ToxicGas="☠️ Toxic Gas", SuperHeat="🌡️ Super Heat", IceStorm="❄️ Ice Storm",
    ThunderStorm="⛈️ Thunder Storm", MeteorShower="☄️ Meteor Shower", HailStorm="🌨️ Hail",
}
local DIS_KWS = {"flood","fire","meteor","earthquake","quake","tsunami","tornado","blizzard","acid","sand","volcan","toxic","heat","hail","lightning","ice","thunder"}

local function getDisaster()
    for name, disp in pairs(DIS_EXACT) do
        if workspace:FindFirstChild(name) then return disp end
    end
    local skipNames = {}
    for _, p in ipairs(Players:GetPlayers()) do
        skipNames[p.Name] = true
        if p.Character then skipNames[p.Character.Name] = true end
    end
    for _, child in ipairs(workspace:GetChildren()) do
        if child:IsA("Model") and not child:FindFirstChildOfClass("Humanoid") and not skipNames[child.Name] then
            local n = child.Name:lower()
            for _, kw in ipairs(DIS_KWS) do
                if n:find(kw, 1, true) then return "⚠️ " .. child.Name end
            end
        end
    end
    local cd = workspace:FindFirstChild("Countdown") or workspace:FindFirstChild("CountDown")
    if cd then
        local v = tonumber(tostring(cd.Value)) or 0
        if v > 0 then return "⏱️ Active — " .. math.floor(v) .. "s" end
    end
    return "None / Waiting"
end


-- Speed/Jump row: label, textbox, +/- buttons all in one row
local function SpeedJumpRow(parent, labelTxt, order, isJump)
    local F=Instance.new("Frame"); F.BackgroundTransparency=1; F.BorderSizePixel=0
    F.Size=UDim2.new(1,0,0,42); F.LayoutOrder=order or 0; F.Parent=parent
    Pad(F,4,4,PAD_H,PAD_H)

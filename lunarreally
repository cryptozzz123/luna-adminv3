local function spawnOrb()
    local orb = Instance.new("Frame")
    orb.BackgroundColor3      = Color3.fromHSV(math.random() * 0.15 + 0.55, 0.5, 1)
    orb.BackgroundTransparency = 0.2
    orb.BorderSizePixel       = 0
    local sz = math.random(6, 22)
    orb.Size      = UDim2.new(0, sz, 0, sz)
    orb.Position  = UDim2.new(math.random() * 0.95, 0, -0.05, 0)
    orb.ZIndex    = 2
    orb.Parent    = Backdrop
    corner(orb, 999)
    -- Add inner glow dot
    local inner = Instance.new("Frame")
    inner.BackgroundColor3      = Color3.new(1, 1, 1)
    inner.BackgroundTransparency = 0.5
    inner.BorderSizePixel       = 0
    inner.AnchorPoint           = Vector2.new(0.3, 0.3)
    inner.Position              = UDim2.new(0.2, 0, 0.2, 0)
    inner.Size                  = UDim2.new(0.3, 0, 0.3, 0)
    inner.ZIndex                = 3
    inner.Parent                = orb
    corner(inner, 999)

    local fallTime = math.random(30, 65) / 10
    local drift    = math.random(-80, 80)
    local endX     = orb.Position.X.Scale + drift / 1000
    TwnSvc:Create(orb, TweenInfo.new(fallTime, Enum.EasingStyle.Linear), {
        Position              = UDim2.new(math.clamp(endX, 0, 0.98), 0, 1.05, 0),
        BackgroundTransparency = 1,
        Size                  = UDim2.new(0, sz * 0.6, 0, sz * 0.6),
    }):Play()
    -- slight swing using rotation tween
    local swingInfo = TweenInfo.new(fallTime / 3, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true)
    TwnSvc:Create(orb, swingInfo, {Rotation = math.random(-12, 12)}):Play()

    task.delay(fallTime + 0.5, function()
        pcall(function() orb:Destroy() end)
    end)
end

